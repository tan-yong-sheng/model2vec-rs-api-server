# Model configuration
MODEL_NAME=minishlab/potion-base-8M

# Optional model alias for embedding requests
ALIAS_MODEL_NAME=minishlab-potion-base-8M

# Server port
PORT=8080

# Lazy load model (optional) - set to true to delay model loading until first request
# Default: false (model loads at startup)
# Recommended: false for small models, true for large models (128M+) to reduce startup time
# Note: On serverless platforms that scale to zero (e.g., Modal), lazy load can increase cold-start latency.
LAZY_LOAD_MODEL=false

# Model unloading (optional) - set to true to unload model from memory when idle
# Default: false (model stays in memory once loaded)
# Recommended: true for large models (128M+) to save memory during idle periods
# Note: On serverless platforms that scale to zero, unloading is usually unnecessary and can add latency.
MODEL_UNLOAD_ENABLED=false

# Idle timeout in seconds before unloading model (only used if MODEL_UNLOAD_ENABLED=true)
# Default: 1800 (30 minutes)
# Note: First request after unload will take 2-3 minutes to reload the model
MODEL_UNLOAD_IDLE_TIMEOUT=1800

# Authentication (optional) - comma-separated bearer tokens
# AUTHENTICATION_ALLOWED_TOKENS=token1,token2,token3

# Request limits and timeouts
REQUEST_TIMEOUT_SECS=30
REQUEST_BODY_LIMIT_BYTES=2000000
MAX_INPUT_ITEMS=512
MAX_INPUT_CHARS=8192
MAX_TOTAL_CHARS=200000
CONCURRENCY_LIMIT=64

# Model load retry settings
MODEL_LOAD_MAX_RETRIES=5
MODEL_LOAD_RETRY_BASE_MS=200
MODEL_LOAD_RETRY_MAX_MS=5000
MODEL_LOAD_TIMEOUT_SECS=120

# Inference retry settings
INFERENCE_MAX_RETRIES=2
INFERENCE_RETRY_BASE_MS=50
INFERENCE_RETRY_MAX_MS=500

# Embedding cache settings
EMBEDDING_CACHE_MAX_ENTRIES=1024
EMBEDDING_CACHE_TTL_SECS=600
